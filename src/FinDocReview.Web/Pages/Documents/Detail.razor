@page "/documents/{Id:guid}"
@using FinDocReview.Core.Entities
@using FinDocReview.Infrastructure.Services
@using System.Text.Json
@inject DocumentService DocumentService
@inject QaService QaService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Document Detail</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (_isLoading)
        {
            <p>Loading...</p>
        }
        else if (_document == null)
        {
            <div class="alert alert-danger">Document not found.</div>
        }
        else
        {
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/documents">Documents</a></li>
                    <li class="breadcrumb-item active">@_document.FileName</li>
                </ol>
            </nav>

            <div class="row">
                <!-- Left column: document info + summary -->
                <div class="col-md-6">
                    <div class="card mb-3">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <strong>@_document.FileName</strong>
                            <span class="badge @GetStatusBadgeClass(_document.Status)">
                                @_document.Status
                            </span>
                        </div>
                        <div class="card-body">
                            <small class="text-muted">
                                Uploaded: @_document.UploadedAt.ToString("yyyy-MM-dd HH:mm")
                                @if (_document.ProcessedAt.HasValue)
                                {
                                    <span> · Processed: @_document.ProcessedAt.Value.ToString("yyyy-MM-dd HH:mm")</span>
                                }
                            </small>
                        </div>
                    </div>

                    @if (_document.Summary != null)
                    {
                        <div class="card mb-3">
                            <div class="card-header"><strong>AI Summary</strong></div>
                            <div class="card-body">
                                <p>@_document.Summary.Summary</p>

                                @if (!string.IsNullOrEmpty(_document.Summary.KeyRisksJson))
                                {
                                    var risks = JsonSerializer.Deserialize<List<string>>(
                                        _document.Summary.KeyRisksJson);
                                    if (risks?.Count > 0)
                                    {
                                        <h6 class="mt-3">Key Risks</h6>
                                        <ul>
                                            @foreach (var risk in risks)
                                            {
                                                <li>@risk</li>
                                            }
                                        </ul>
                                    }
                                }

                                @if (!string.IsNullOrEmpty(_document.Summary.ActionItemsJson))
                                {
                                    var items = JsonSerializer.Deserialize<List<string>>(
                                        _document.Summary.ActionItemsJson);
                                    if (items?.Count > 0)
                                    {
                                        <h6 class="mt-3">Action Items</h6>
                                        <ul>
                                            @foreach (var item in items)
                                            {
                                                <li>@item</li>
                                            }
                                        </ul>
                                    }
                                }

                                <small class="text-muted">
                                    Model: @_document.Summary.ModelUsed ·
                                    Generated: @_document.Summary.GeneratedAt.ToString("yyyy-MM-dd HH:mm")
                                </small>
                            </div>
                        </div>
                    }
                    else if (_document.Status == DocumentStatus.Processing)
                    {
                        <div class="alert alert-info">
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            Processing document, please wait...
                        </div>
                    }
                    else if (_document.Status == DocumentStatus.Failed)
                    {
                        <div class="alert alert-danger">
                            Processing failed: @_document.ErrorMessage
                        </div>
                    }
                </div>

                <!-- Right column: Q&A -->
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header"><strong>Ask a Question</strong></div>
                        <div class="card-body">
                            @if (_document.Status != DocumentStatus.Completed)
                            {
                                <div class="alert alert-warning">
                                    Q&A is available after document processing completes.
                                </div>
                            }
                            else
                            {
                                <div class="mb-3">
                                    <textarea class="form-control"
                                              rows="3"
                                              placeholder="Ask anything about this document..."
                                              @bind="_question"
                                              disabled="@_isAsking">
                                    </textarea>
                                </div>
                                <button class="btn btn-primary mb-3"
                                        @onclick="AskQuestion"
                                        disabled="@(string.IsNullOrWhiteSpace(_question) || _isAsking)">
                                    @if (_isAsking)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Thinking...</span>
                                    }
                                    else
                                    {
                                        <span>Ask</span>
                                    }
                                </button>

                                @if (!string.IsNullOrEmpty(_errorMessage))
                                {
                                    <div class="alert alert-danger">@_errorMessage</div>
                                }

                                @if (_queryLogs.Count > 0)
                                {
                                    <hr />
                                    <h6>Recent Questions</h6>
                                    @foreach (var log in _queryLogs)
                                    {
                                        <div class="mb-3 p-3 bg-light rounded">
                                            <div class="fw-bold text-primary mb-1">Q: @log.UserPrompt</div>
                                            <div class="mb-1">@log.AiResponse</div>
                                            <small class="text-muted">
                                                @log.CreatedAt.ToString("HH:mm:ss") ·
                                                @log.LatencyMs ms ·
                                                @log.ModelUsed
                                            </small>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning">
            Please <a href="/Identity/Account/Login">log in</a> to view documents.
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public Guid Id { get; set; }

    private Document? _document;
    private bool _isLoading = true;
    private string _question = string.Empty;
    private bool _isAsking;
    private string? _errorMessage;
    private List<AiQueryLog> _queryLogs = [];
    private string? _userId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(_userId))
        {
            _document = await DocumentService.GetDocumentAsync(Id, _userId);
            if (_document != null)
                _queryLogs = _document.QueryLogs.ToList();
        }

        _isLoading = false;
    }

    private async Task AskQuestion()
    {
        if (string.IsNullOrWhiteSpace(_question) || _userId == null) return;

        _isAsking = true;
        _errorMessage = null;

        try
        {
            var log = await QaService.AskAsync(Id, _userId, _question);
            _queryLogs.Insert(0, log);
            _question = string.Empty;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isAsking = false;
        }
    }

    private static string GetStatusBadgeClass(DocumentStatus status) => status switch
    {
        DocumentStatus.Pending => "bg-secondary",
        DocumentStatus.Processing => "bg-warning text-dark",
        DocumentStatus.Completed => "bg-success",
        DocumentStatus.Failed => "bg-danger",
        _ => "bg-secondary"
    };
}